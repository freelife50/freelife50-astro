---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { slugifyTag } from '../utils/slug';

interface Props {
  title: string;
  date: string;
  categories: string[];
  tags: string[];
  eyecatch?: string;
  snsImage?: string;
  excerpt?: string;
  lang?: string;
  slug?: string;
  hreflangJaUrl?: string;
  hreflangEnUrl?: string;
}

const {
  title,
  date,
  categories,
  tags,
  eyecatch,
  snsImage,
  excerpt,
  lang = 'ja',
  slug,
  hreflangJaUrl,
  hreflangEnUrl,
} = Astro.props;

const JA_SITE = 'https://freelife50.com';
const EN_SITE = 'https://en.freelife50.com';
const canonicalBase = lang === 'en' ? EN_SITE : JA_SITE;
const canonicalUrl = slug ? `${canonicalBase}/${slug}/` : canonicalBase;
const imageUrl = snsImage
  ? new URL(snsImage, canonicalBase).toString()
  : eyecatch
    ? new URL(eyecatch, canonicalBase).toString()
    : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  ...(excerpt ? { description: excerpt } : {}),
  datePublished: date,
  dateModified: date,
  author: {
    '@type': 'Person',
    name: lang === 'en' ? 'Hiroshi' : 'ひろし',
    url: lang === 'en' ? `${EN_SITE}/profile/` : `${JA_SITE}/profile/`,
  },
  publisher: {
    '@type': 'Organization',
    name: 'ラーメンとビールと時々ブログ',
    url: lang === 'en' ? EN_SITE : JA_SITE,
    logo: {
      '@type': 'ImageObject',
      url: `${JA_SITE}/images/wp-content/uploads/2025/04/8d3acb8ac16d829c946f739ad4181f54.png`,
    },
  },
  url: canonicalUrl,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  ...(imageUrl ? { image: imageUrl } : {}),
  ...(lang === 'en'
    ? { inLanguage: 'en' }
    : { inLanguage: 'ja' }),
};

const catNames: Record<string, string> = {
  'blog-sidejob': 'ブログ運営と副業',
  'life-with-momiji': 'もみじと暮らす',
  'prepared-life': '備えと暮らし',
  'healing-walks': '癒しと散策',
  'society-issues-thoughts': '社会・時事・思考',
  'shumi-taiken-etc': '趣味・体験・その他',
  'food-nostalgia': '食と懐かしさ',
};

const catNamesEn: Record<string, string> = {
  'blog-sidejob': 'Blogging & Side Hustles',
  'life-with-momiji': 'Life with Momiji',
  'prepared-life': 'Preparedness & Daily Life',
  'healing-walks': 'Healing & Walks',
  'society-issues-thoughts': 'Society, News & Reflections',
  'shumi-taiken-etc': 'Hobbies, Experiences & More',
  'food-nostalgia': 'Food & Nostalgia',
};

const activeCatNames = lang === 'en' ? catNamesEn : catNames;
const catBase = lang === 'en' ? '/en/category/' : '/category/';
const tagBase = lang === 'en' ? '/en/tag/' : '/tag/';
const tagItems = tags.map(tag => ({ label: tag, slug: slugifyTag(tag) }));

const dateLocale = lang === 'en' ? 'en-US' : 'ja-JP';
const formattedDate = new Date(date).toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout
  title={title}
  description={excerpt}
  ogImage={snsImage ?? eyecatch}
  ogType="article"
  lang={lang}
  hreflangJaUrl={hreflangJaUrl}
  hreflangEnUrl={hreflangEnUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <div class="layout-wrap">
    <article>
      <header class="post-header">
        <h1 class="post-title">{title}</h1>
        <div class="post-meta">
          <time datetime={date}>{formattedDate}</time>
          {categories.map(cat => (
            <a href={`${catBase}${cat}/`} class="cat-badge">{activeCatNames[cat] || cat}</a>
          ))}
        </div>
      </header>

      {eyecatch && (
        <div class="post-eyecatch">
          <img src={eyecatch} alt={title} />
        </div>
      )}

      <div class="post-content">
        <slot />
      </div>

      {tags.length > 0 && (
        <div class="tag-list">
          {tagItems.map(tag => (
            <span class="tag">
              {tag.slug ? <a href={`${tagBase}${tag.slug}/`}>{tag.label}</a> : tag.label}
            </span>
          ))}
        </div>
      )}
    </article>

    <Sidebar lang={lang === 'en' ? 'en' : 'ja'} />
  </div>
</BaseLayout>

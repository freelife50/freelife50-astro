---
import '../styles/global.css';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  lang?: string;
  /** 英語記事の対応する日本語スラッグ（hreflang 用）。未設定なら出力しない */
  hreflangJaUrl?: string;
  /** 日本語記事の対応する英語スラッグ（hreflang 用）。未設定なら出力しない */
  hreflangEnUrl?: string;
  /**
   * canonical URL を手動で上書きする（例: en/index.astro → "https://en.freelife50.com/"）。
   * Worker のリライトで実際の URL と Astro の pathname がずれる場合に使用。
   */
  canonicalOverride?: string;
}

const {
  title,
  description = 'ラーメンとビールと時々ブログ | Ramen, Beer & Blog',
  ogImage,
  ogType = 'website',
  lang = 'ja',
  hreflangJaUrl,
  hreflangEnUrl,
  canonicalOverride,
} = Astro.props;
const siteTitle = 'ラーメンとビールと時々ブログ';

// 言語によって canonical のベース URL を切り替える
const JA_SITE = 'https://freelife50.com';
const EN_SITE = 'https://en.freelife50.com';
const canonicalBase = lang === 'en' ? EN_SITE : JA_SITE;
// en/index.astro など、Worker リライトで実際 URL が変わるケースは手動上書き
const canonicalUrl = canonicalOverride ?? new URL(Astro.url.pathname, canonicalBase).toString();

const SITE_DEFAULT_OG_IMAGE = '/images/wp-content/uploads/2025/04/8d3acb8ac16d829c946f739ad4181f54.png';
const resolvedOgImage = new URL(ogImage ?? SITE_DEFAULT_OG_IMAGE, canonicalBase).toString();

const categories = [
  { slug: 'blog-sidejob', name: 'ブログ運営と副業' },
  { slug: 'life-with-momiji', name: 'もみじと暮らす' },
  { slug: 'prepared-life', name: '備えと暮らし' },
  { slug: 'healing-walks', name: '癒しと散策' },
  { slug: 'society-issues-thoughts', name: '社会・時事・思考' },
  { slug: 'shumi-taiken-etc', name: '趣味・体験・その他' },
  { slug: 'food-nostalgia', name: '食と懐かしさ' },
];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title === siteTitle ? title : `${title} | ${siteTitle}`}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={ogType} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={resolvedOgImage} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <!-- hreflang: 英語記事には ja/en/x-default を付与 -->
  {hreflangEnUrl && (
    <>
      <link rel="alternate" hreflang="ja" href={`${JA_SITE}${Astro.url.pathname}`} />
      <link rel="alternate" hreflang="en" href={hreflangEnUrl} />
      <link rel="alternate" hreflang="x-default" href={`${JA_SITE}${Astro.url.pathname}`} />
    </>
  )}
  {hreflangJaUrl && (
    <>
      <link rel="alternate" hreflang="en" href={`${EN_SITE}${Astro.url.pathname}`} />
      <link rel="alternate" hreflang="ja" href={hreflangJaUrl} />
      <link rel="alternate" hreflang="x-default" href={hreflangJaUrl} />
    </>
  )}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
  <GoogleAnalytics />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <div class="site-title">
        <a href="/">
          {siteTitle}
          <small>Ramen, Beer &amp; Blog</small>
        </a>
      </div>
      <nav class="site-nav">
        {categories.slice(0, 4).map(cat => (
          <a href={`/category/${cat.slug}/`}>{cat.name}</a>
        ))}
      </nav>
    </div>
  </header>

  <main class="page-main">
    <div class="container">
      <slot />
    </div>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} {siteTitle}</p>
    </div>
  </footer>
</body>
</html>

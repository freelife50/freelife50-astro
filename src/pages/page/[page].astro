---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import Pagination from '../../components/Pagination.astro';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allPosts = await getCollection('blog');
  // freelife50.com は日本語記事のみ（lang: en を除外）
  const sorted = allPosts
    .filter(p => p.data.lang !== 'en')
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

  // paginate() が /page/1, /page/2 ... を生成するが、
  // 1ページ目は index.astro が担当するので除外
  return paginate(sorted, { pageSize: 10 })
    .filter(({ params }: { params: { page: string } }) => params.page !== '1');
}

const { page } = Astro.props as { page: any };

// 2ページ目の「前へ」はルートURL「/」に向ける
const prevUrl = page.currentPage === 2 ? '/' : page.url.prev;
const nextUrl = page.url.next;
---
<BaseLayout title={`最新記事 ${page.currentPage}ページ目 | ラーメンとビールと時々ブログ`}>
  <div class="layout-wrap">
    <div>
      <h1 style="font-size:1.1rem;color:#666;margin-bottom:20px;">最新記事</h1>
      {page.data.map((post: any) => (
        <PostCard
          title={post.data.title}
          slug={post.data.slug}
          date={post.data.date}
          categories={post.data.categories}
          eyecatch={post.data.eyecatch}
          excerpt={post.data.excerpt}
        />
      ))}
      <Pagination
        currentPage={page.currentPage}
        totalPages={page.lastPage}
        prevUrl={prevUrl}
        nextUrl={nextUrl}
      />
    </div>
    <Sidebar />
  </div>
</BaseLayout>

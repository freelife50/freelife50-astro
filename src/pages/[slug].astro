---
import { getCollection, render } from 'astro:content';
import PostLayout from '../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // __trashedなど無効なスラッグを除外
  return posts
    .filter(post => post.data.slug && !post.data.slug.startsWith('__'))
    .map(post => ({
      params: { slug: post.data.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('blog');
const postsBySlug = new Map(allPosts.map(item => [item.data.slug, item]));
const slug = post.data.slug;
const alternateSlug = post.data.alternateSlug
  ?? (post.data.lang === 'en' && slug.endsWith('-en') ? slug.slice(0, -3) : undefined)
  ?? (post.data.lang !== 'en' && postsBySlug.has(`${slug}-en`) ? `${slug}-en` : undefined);

const hreflangJaUrl = post.data.lang === 'en' && alternateSlug && postsBySlug.has(alternateSlug)
  ? `https://freelife50.com/${alternateSlug}/`
  : undefined;

const hreflangEnUrl = post.data.lang !== 'en' && alternateSlug && postsBySlug.has(alternateSlug)
  ? `https://en.freelife50.com/${alternateSlug}/`
  : undefined;
---
<PostLayout
  title={post.data.title}
  date={post.data.date}
  categories={post.data.categories}
  tags={post.data.tags}
  eyecatch={post.data.eyecatch}
  snsImage={post.data.sns_image_url}
  excerpt={post.data.excerpt}
  lang={post.data.lang}
  slug={post.data.slug}
  hreflangJaUrl={hreflangJaUrl}
  hreflangEnUrl={hreflangEnUrl}
>
  <Content />
</PostLayout>

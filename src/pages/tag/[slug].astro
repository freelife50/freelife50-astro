---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import { slugifyTag } from '../../utils/slug';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  // freelife50.com は日本語記事のみ（lang: en を除外）
  const jaPosts = allPosts.filter(p => p.data.lang !== 'en');
  const tagMap = new Map<string, string[]>();

  for (const tag of new Set(jaPosts.flatMap(p => p.data.tags))) {
    if (tag.length >= 100) continue;
    const slug = slugifyTag(tag);
    if (!slug) continue;
    tagMap.set(slug, [...(tagMap.get(slug) ?? []), tag]);
  }

  return Array.from(tagMap.entries()).map(([slug, tagLabels]) => ({
    params: { slug },
    props: {
      posts: jaPosts
        .filter(p => p.data.tags.some(tag => tagLabels.includes(tag)))
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
      tag: tagLabels[0],
    },
  }));
}

const { posts, tag } = Astro.props;
---
<BaseLayout title={`タグ: ${tag}`}>
  <div class="layout-wrap">
    <div>
      <h1 class="archive-heading">タグ: <span>{tag}</span></h1>
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          slug={post.data.slug}
          date={post.data.date}
          categories={post.data.categories}
          eyecatch={post.data.eyecatch}
          excerpt={post.data.excerpt}
        />
      ))}
    </div>
    <Sidebar />
  </div>
</BaseLayout>

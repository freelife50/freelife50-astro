---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import Pagination from '../../components/Pagination.astro';
import { getPublicPosts, languageMatches, sortByNewest } from '../../utils/posts';

const PAGE_SIZE = 10;

const allPosts = getPublicPosts(await getCollection('blog'));
// en.freelife50.com は英語記事のみ（lang: en）
const sorted = sortByNewest(allPosts.filter(p => languageMatches(p, 'en')));

const posts = sorted.slice(0, PAGE_SIZE);
const totalPages = Math.ceil(sorted.length / PAGE_SIZE);
const popularSlugs = ['atsugi-kodomo-no-mori-park-en'];
const popularPosts = popularSlugs
  .map(slug => sorted.find(post => post.data.slug === slug))
  .filter(Boolean);
---
<BaseLayout
  title="Ramen, Beer &amp; Blog — English Articles"
  description="Life stories from a 50s Japanese blogger — hiking, dogs, family, and more."
  lang="en"
  canonicalOverride="https://en.freelife50.com/"
>
  <div class="layout-wrap">
    <div>
      {popularPosts.length > 0 && (
        <section class="home-highlight" aria-labelledby="popular-heading">
          <div>
            <p class="home-highlight__label">Reader activity</p>
            <h1 id="popular-heading">Popular English reads</h1>
            <p class="home-highlight__lead">Start with the English article that is already getting visits, then keep browsing from the latest posts.</p>
          </div>
          <ul class="home-highlight__list">
            {popularPosts.map(post => (
              <li>
                <a href={`/${post.data.slug}/`}>{post.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )}
      <h1 style="font-size:1.1rem;color:#666;margin-bottom:20px;">Latest Articles</h1>
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          slug={post.data.slug}
          date={post.data.date}
          categories={post.data.categories}
          eyecatch={post.data.eyecatch}
          excerpt={post.data.excerpt}
          lang="en"
        />
      ))}
      {totalPages > 1 && (
        <Pagination
          currentPage={1}
          totalPages={totalPages}
          nextUrl={totalPages > 1 ? '/en/page/2/' : undefined}
        />
      )}
    </div>
    <Sidebar lang="en" />
  </div>
</BaseLayout>

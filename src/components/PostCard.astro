---
import sharp from 'sharp';
import { join } from 'path';
import { existsSync } from 'fs';

interface Props {
  title: string;
  slug: string;
  date: string;
  categories: string[];
  eyecatch?: string;
  excerpt?: string;
  lang?: 'ja' | 'en';
}

const { title, slug, date, categories, eyecatch, excerpt, lang = 'ja' } = Astro.props;

const catNames: Record<string, string> = {
  'blog-sidejob': 'ブログ運営と副業',
  'life-with-momiji': 'もみじと暮らす',
  'prepared-life': '備えと暮らし',
  'healing-walks': '癒しと散策',
  'society-issues-thoughts': '社会・時事・思考',
  'shumi-taiken-etc': '趣味・体験・その他',
  'food-nostalgia': '食と懐かしさ',
};

const catNamesEn: Record<string, string> = {
  'blog-sidejob': 'Blogging & Side Hustles',
  'life-with-momiji': 'Life with Momiji',
  'prepared-life': 'Preparedness & Daily Life',
  'healing-walks': 'Healing & Walks',
  'society-issues-thoughts': 'Society, News & Reflections',
  'shumi-taiken-etc': 'Hobbies, Experiences & More',
  'food-nostalgia': 'Food & Nostalgia',
};

// ビルド時に画像の縦横比を判定（?v=... クエリストリングを除去してからパス解決）
let isPortrait = false;
if (eyecatch) {
  const eyecatchClean = eyecatch.split('?')[0];
  const imagePath = join(process.cwd(), 'public', eyecatchClean);
  if (existsSync(imagePath)) {
    try {
      const meta = await sharp(imagePath).metadata();
      isPortrait = (meta.height ?? 0) > (meta.width ?? 1);
    } catch {
      // 判定失敗時は横長扱い
    }
  }
}

const thumbClass = isPortrait
  ? 'post-card__thumb post-card__thumb--portrait'
  : 'post-card__thumb';

const isEn = lang === 'en';
const activeCatNames = isEn ? catNamesEn : catNames;
const catBase = isEn ? '/en/category/' : '/category/';
const formattedDate = new Date(date).toLocaleDateString(isEn ? 'en-US' : 'ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---
<article class="post-card">
  {eyecatch
    ? <img class={thumbClass} src={eyecatch} alt={title} loading="lazy" />
    : <div class="post-card__thumb-placeholder">No Image</div>
  }
  <div class="post-card__body">
    <div class="post-card__meta">
      <time datetime={date}>{formattedDate}</time>
      {categories.map(cat => (
        <a href={`${catBase}${cat}/`} class="cat-badge">{activeCatNames[cat] || cat}</a>
      ))}
    </div>
    <h2 class="post-card__title">
      <a href={`/${slug}/`}>{title}</a>
    </h2>
    {excerpt && <p class="post-card__excerpt">{excerpt.slice(0, 100)}...</p>}
  </div>
</article>

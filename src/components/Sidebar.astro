---
import { getCollection } from 'astro:content';
import { getPublicPosts, languageMatches, sortByNewest } from '../utils/posts';

interface Props {
  lang?: 'ja' | 'en';
}
const { lang = 'ja' } = Astro.props;

const allPosts = getPublicPosts(await getCollection('blog'));
const published = sortByNewest(allPosts);

const isEn = lang === 'en';
const recent = published.filter(p => languageMatches(p, lang)).slice(0, 5);
const languagePosts = published.filter(p => languageMatches(p, lang));
const popularSlugs = isEn
  ? ['atsugi-kodomo-no-mori-park-en']
  : ['atsugi-kodomo-no-mori-park', 'coconala-phone-fortune-telling-50s', 'zama-serizawa-park-underground-factory'];
const popular = popularSlugs
  .map(slug => languagePosts.find(post => post.data.slug === slug))
  .filter(Boolean)
  .slice(0, 4);

const categories = [
  { slug: 'blog-sidejob', name: 'ブログ運営と副業', nameEn: 'Blogging & Side Hustles' },
  { slug: 'life-with-momiji', name: 'もみじと暮らす', nameEn: 'Life with Momiji' },
  { slug: 'prepared-life', name: '備えと暮らし', nameEn: 'Preparedness & Daily Life' },
  { slug: 'healing-walks', name: '癒しと散策', nameEn: 'Healing & Walks' },
  { slug: 'society-issues-thoughts', name: '社会・時事・思考', nameEn: 'Society, News & Reflections' },
  { slug: 'shumi-taiken-etc', name: '趣味・体験・その他', nameEn: 'Hobbies, Experiences & More' },
  { slug: 'food-nostalgia', name: '食と懐かしさ', nameEn: 'Food & Nostalgia' },
];

// カテゴリ別記事数（言語でフィルタ）
const catCount: Record<string, number> = {};
for (const post of published) {
  if (languageMatches(post, lang)) {
    for (const cat of post.data.categories) {
      catCount[cat] = (catCount[cat] || 0) + 1;
    }
  }
}

const categoryBase = isEn ? '/en/category/' : '/category/';
---
<aside class="sidebar">
  <div class="sidebar-widget sidebar-search">
    <h3>{isEn ? 'Search' : '検索'}</h3>
    <form action="https://www.google.com/search" method="get">
      <input type="hidden" name="sitesearch" value={isEn ? 'en.freelife50.com' : 'freelife50.com'} />
      <input type="text" name="q" placeholder={isEn ? 'Search English articles...' : 'サイト内を検索...'} autocomplete="search" />
    </form>
  </div>

  {popular.length > 0 && (
    <div class="sidebar-widget sidebar-popular">
      <h3>{isEn ? 'Popular Reads' : 'よく読まれている記事'}</h3>
      <ul>
        {popular.map(post => (
          <li>
            <a href={`/${post.data.slug}/`}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <div class="sidebar-widget">
    <h3>{isEn ? 'Recent Posts' : '最近の投稿'}</h3>
    <ul>
      {recent.map(post => (
        <li>
          <a href={`/${post.data.slug}/`}>{post.data.title}</a>
        </li>
      ))}
    </ul>
  </div>

  <div class="sidebar-widget">
    <h3>{isEn ? 'Categories' : 'カテゴリ'}</h3>
    <ul>
      {categories.map(cat => (
        <li>
          <a href={`${categoryBase}${cat.slug}/`}>
            {isEn ? cat.nameEn : cat.name} ({catCount[cat.slug] || 0})
          </a>
        </li>
      ))}
    </ul>
  </div>
</aside>
